  "query": "\n            SELECT\n                id          AS \"id!: Uuid\",\n                project_id  AS \"project_id!: Uuid\",\n                name        AS \"name!\",\n                starts_at   AS \"starts_at: DateTime<Utc>\",\n                ends_at     AS \"ends_at: DateTime<Utc>\",\n                state       AS \"state!: SprintState\",\n                created_at  AS \"created_at!: DateTime<Utc>\",\n                updated_at  AS \"updated_at!: DateTime<Utc>\"\n            FROM sprints\n            WHERE project_id = $1\n            ORDER BY created_at\n            ",
