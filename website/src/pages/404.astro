---
import '../styles/tasca.css';
import '../styles/tokens.css';
import '../styles/a11y.css';
import { MARK, I, APP_URL } from '../lib/icons';

const compass = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M15.5 8.5l-2 5-5 2 2-5 5-2Z" stroke-linejoin="round"/></svg>';
---
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tasca — Page not found</title>
  <meta name="robots" content="noindex" />
  <script is:inline>
    (function () { try { document.documentElement.setAttribute('data-theme', localStorage.getItem('tasca-theme') || 'dark'); } catch (e) {} })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <div class="err-stage">
    <div class="err-top">
      <a class="err-brand" href="/"><span class="err-mark" set:html={MARK} /><span class="brand-word"><span class="a">Tas</span><span class="b">ca</span></span></a>
    </div>
    <div class="err-body"><div class="err-card">
      <div class="err-code">Error 404 · Not found</div>
      <div class="err-ico" set:html={compass} />
      <div class="err-num">404</div>
      <h1>This page isn’t on the roster</h1>
      <p>The link may be broken, or the agent, task, or connection it pointed to was moved or retired. Nothing’s wrong with your account — this address just doesn’t resolve.</p>
      <div class="err-actions">
        <a class="btn-add" href={APP_URL}><span set:html={I.roster} /> Go to your team</a>
        <a class="btn-ghost" href="/">Back to home</a>
      </div>
      <div class="err-links"><a href="/docs">Docs</a><span class="sep">·</span><a href="/product">Product</a></div>
      <div class="err-ref">path · /agents/unknown</div>
    </div></div>
  </div>

  <style>
    html, body { height: 100%; margin: 0; }
    body { background: var(--bg); font-family: var(--font-body); color: var(--fg-2); }
    .err-stage { min-height: 100vh; display: flex; flex-direction: column; }
    .err-top { display: flex; align-items: center; justify-content: space-between; height: 60px; padding: 0 28px; border-bottom: 1px solid var(--line); }
    .err-brand { display: inline-flex; align-items: center; gap: 10px; }
    .err-mark { width: 24px; height: 24px; display: inline-grid; color: var(--fg); }
    .brand-word { font-family: var(--font-display); font-size: 18px; font-weight: 700; letter-spacing: -0.03em; }
    .brand-word .a { color: var(--fg); } .brand-word .b { color: var(--fg-4); }
    .err-body { flex: 1; display: flex; align-items: center; justify-content: center; padding: 48px 24px; }
    .err-card { width: 100%; max-width: 560px; text-align: center; display: flex; flex-direction: column; align-items: center; }
    .err-code { font-family: var(--font-mono); font-size: var(--fs-xs); letter-spacing: 0.18em; text-transform: uppercase; color: var(--fg-4); }
    .err-ico { width: 72px; height: 72px; border-radius: var(--radius-lg); display: grid; place-items: center; margin: 18px 0 22px; border: 1px solid var(--line-2); background: var(--surface); color: var(--fg-3); }
    .err-ico svg { width: 34px; height: 34px; }
    .err-num { font-family: var(--font-display); font-size: 64px; font-weight: 600; letter-spacing: -0.04em; color: var(--fg); line-height: 1; }
    .err-card h1 { font-family: var(--font-display); font-size: var(--fs-xl); font-weight: 600; letter-spacing: -0.025em; color: var(--fg); margin: 14px 0 0; }
    .err-card p { font-size: var(--fs-md); color: var(--fg-3); line-height: 1.6; margin: 12px 0 0; max-width: 460px; }
    .err-actions { display: flex; align-items: center; gap: 12px; margin-top: 28px; flex-wrap: wrap; justify-content: center; }
    .btn-add { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-body); font-weight: 600; font-size: var(--fs-sm); padding: 11px 18px; border-radius: var(--radius-sm); background: var(--signal); color: #04101F; border: none; cursor: pointer; text-decoration: none; transition: background var(--dur) var(--ease), transform var(--dur) var(--ease); }
    .btn-add:hover { background: var(--signal-2); transform: translateY(-1px); }
    .btn-add svg { width: 15px; height: 15px; }
    :root[data-theme="light"] .btn-add { color: #fff; }
    .btn-ghost { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-body); font-weight: 600; font-size: var(--fs-sm); padding: 11px 18px; border-radius: var(--radius-sm); border: 1px solid var(--line-2); background: var(--surface); color: var(--fg-2); cursor: pointer; text-decoration: none; transition: all var(--dur) var(--ease); }
    .btn-ghost:hover { border-color: var(--line-3); color: var(--fg); }
    .err-ref { font-family: var(--font-mono); font-size: var(--fs-2xs); color: var(--fg-faint); margin-top: 26px; }
    .err-links { margin-top: 14px; font-size: var(--fs-sm); display: flex; gap: 10px; align-items: center; color: var(--fg-3); }
    .err-links a { color: var(--signal-2); text-decoration: none; } .err-links a:hover { text-decoration: underline; }
    .err-links .sep { color: var(--fg-faint); }
  </style>
</body>
</html>
