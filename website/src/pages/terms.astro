---
import Base from '../layouts/Base.astro';
import { Content, getHeadings } from '../legal/terms.md';

// Top-level sections (## …) drive the sticky table of contents.
const sections = getHeadings().filter((h) => h.depth === 2);
const updated = 'June 1, 2026';
---
<Base
  title="Terms of Service — Tasca"
  description="The terms governing your use of the Tasca website and the Company-operated hosted service."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Legal</span>
      <h1>Terms of Service</h1>
      <p class="lead">The terms governing your use of the Tasca website and the Company-operated hosted service.</p>
      <p class="updated">Last updated {updated}</p>
    </div>
  </section>

  <div class="container legal-wrap">
    <nav class="legal-toc" aria-label="On this page">
      <div class="th">On this page</div>
      {sections.map((s) => <a href={`#${s.slug}`}>{s.text}</a>)}
    </nav>
    <article class="prose legal-prose">
      <Content />
    </article>
  </div>
</Base>

<style is:global>
  /* Markdown-rendered legal prose — covers elements beyond the base .prose set. */
  .legal-prose > :first-child { margin-top: 0; }
  .legal-prose h2 { margin-top: 44px; scroll-margin-top: 88px; }
  .legal-prose h3 { scroll-margin-top: 88px; }
  .legal-prose blockquote {
    margin-top: 16px; padding: 12px 16px;
    border-left: 3px solid var(--line-3); background: var(--surface-2);
    border-radius: var(--r-sm); color: var(--fg-3);
  }
  .legal-prose blockquote p { margin-top: 0; }
  .legal-prose blockquote p + p { margin-top: 10px; }
  .legal-prose code {
    font-family: var(--f-mono); font-size: 0.9em; color: var(--fg-2);
    background: var(--surface-2); border: 1px solid var(--line-2);
    border-radius: 5px; padding: 1px 6px;
  }
  .legal-prose table { width: 100%; border-collapse: collapse; margin-top: 16px; font-size: 14.5px; }
  .legal-prose th, .legal-prose td { text-align: left; padding: 9px 12px; border: 1px solid var(--line-2); color: var(--fg-3); }
  .legal-prose th { color: var(--fg-2); background: var(--surface-2); font-weight: 600; }
</style>
