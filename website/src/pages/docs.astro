    </aside>
  </div>
</Base>

<style is:global>
  .docs-wrap { max-width: 1320px; margin: 0 auto; padding: 0 var(--pad);
    display: grid; grid-template-columns: 232px minmax(0,1fr) 200px; gap: 48px; align-items: start; }
  @media (max-width: 1080px){ .docs-wrap { grid-template-columns: 220px minmax(0,1fr); } .docs-toc { display: none; } }
  @media (max-width: 760px){ .docs-wrap { grid-template-columns: 1fr; gap: 0; } .docs-nav { display: none; } }

  .docs-nav { position: sticky; top: 88px; padding: 40px 0; align-self: start; }
  .docs-nav .grp { font-family: var(--f-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--fg-4); margin: 22px 0 10px; }
  .docs-nav .grp:first-child { margin-top: 0; }
  .docs-nav a { display: block; font-size: 14px; color: var(--fg-3); padding: 6px 12px; border-radius: var(--r-sm);
    border-left: 2px solid transparent; transition: color var(--dur), background var(--dur), border-color var(--dur); }
  .docs-nav a:hover { color: var(--fg); background: var(--surface); }
  .docs-nav a.active { color: var(--signal-2); border-left-color: var(--signal); background: color-mix(in srgb, var(--signal) 7%, transparent); }

  .docs-main { padding: 40px 0 100px; min-width: 0; }
  .docs-kicker { font-family: var(--f-mono); font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--signal); }
  .docs-main h1 { font-size: clamp(34px, 4.5vw, 46px); margin-top: 14px; letter-spacing: -0.03em; }
  .docs-lead { font-size: 18px; color: var(--fg-3); line-height: 1.6; margin-top: 16px; max-width: 640px; }
  .docs-sec { margin-top: 56px; scroll-margin-top: 88px; }
  .docs-sec h2 { font-size: 26px; letter-spacing: -0.02em; padding-bottom: 14px; border-bottom: 1px solid var(--line); }
  .docs-sec h3 { font-size: 17px; margin-top: 28px; color: var(--fg); }
  .docs-sec p { color: var(--fg-3); line-height: 1.7; margin-top: 14px; }
  .docs-sec p a, .docs-sec li a { color: var(--signal-2); }
  .docs-sec p a:hover, .docs-sec li a:hover { text-decoration: underline; }
  .docs-sec ul { margin: 14px 0 0 0; padding-left: 0; list-style: none; display: flex; flex-direction: column; gap: 10px; }
  .docs-sec ul li { position: relative; padding-left: 20px; color: var(--fg-3); line-height: 1.6; }
  .docs-sec ul li::before { content: ""; position: absolute; left: 4px; top: 10px; width: 5px; height: 5px; border-radius: 1px; background: var(--signal); }
  .docs-sec .code { margin-top: 18px; }
  .kbd { font-family: var(--f-mono); font-size: 12.5px; background: var(--surface-2); border: 1px solid var(--line-2); border-radius: 5px; padding: 1px 6px; color: var(--fg-2); }
  .note { margin-top: 20px; border: 1px solid var(--line); border-left: 2px solid var(--signal); background: color-mix(in srgb, var(--signal) 5%, var(--surface)); border-radius: var(--r-md); padding: 16px 18px; }
  .note .nh { font-family: var(--f-mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--signal-2); }
  .note p { margin-top: 6px; color: var(--fg-2); font-size: 14.5px; }

  .docs-toc { position: sticky; top: 88px; padding: 40px 0; }
  .docs-toc .th { font-family: var(--f-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--fg-4); margin-bottom: 12px; }
  .docs-toc a { display: block; font-size: 13px; color: var(--fg-4); padding: 5px 0; line-height: 1.4; transition: color var(--dur); }
  .docs-toc a:hover, .docs-toc a.active { color: var(--fg-2); }

  .tier-table { width: 100%; border-collapse: collapse; margin-top: 18px; font-size: 14px; }
  .tier-table th { text-align: left; font-family: var(--f-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--fg-4); padding: 0 14px 10px 0; font-weight: 500; border-bottom: 1px solid var(--line); }
  .tier-table td { padding: 14px 14px 14px 0; border-bottom: 1px solid var(--line); color: var(--fg-3); vertical-align: top; line-height: 1.5; }
  .docs-mobilebar { display: none; }
  @media (max-width: 760px){ .docs-mobilebar { display: flex; gap: 8px; overflow-x: auto; padding: 14px var(--pad); border-bottom: 1px solid var(--line); position: sticky; top: 64px; background: var(--bg); z-index: 40; }
    .docs-mobilebar a { font-family: var(--f-mono); font-size: 12px; color: var(--fg-3); white-space: nowrap; padding: 5px 11px; border: 1px solid var(--line); border-radius: var(--r-tag); } }
</style>
