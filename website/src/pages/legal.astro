---
import Base from '../layouts/Base.astro';
import { Content as TermsContent } from '../legal/terms.md';
import { Content as PrivacyContent } from '../legal/privacy.md';

const docs = [
  { key: 'terms', label: 'Terms' },
  { key: 'privacy', label: 'Privacy' },
];
---
<Base
  title="Tasca — Legal"
  description="Tasca's Terms of Service and Privacy Policy — the agreements and policies that govern your use of the platform."
>
  <section class="phero"><div class="wrap-narrow">
    <span class="kicker">Legal</span>
    <h1>Terms &amp; policies</h1>
    <p>The agreements and policies that govern your use of Tasca. Operated by ICEMINT, LLC.</p>
  </div></section>

  <section class="sec-sm"><div class="wrap-narrow">
    <div class="legal-tabs">
      {docs.map((d, i) => <button class={`legal-tab ${i === 0 ? 'on' : ''}`} data-k={d.key}>{d.label}</button>)}
    </div>
    <div class="prose legal-doc" data-k="terms"><TermsContent /></div>
    <div class="prose legal-doc" data-k="privacy" style="display:none"><PrivacyContent /></div>
  </div></section>
</Base>

<style>
  /* Markdown-rendered legal docs: extend the design's .prose for full GFM output. */
  .prose h1 { font-family: var(--font-display); font-size: var(--fs-2xl); font-weight: 600; color: var(--fg); letter-spacing: -0.025em; margin: 0 0 4px; }
  .prose h2 { margin-top: 40px; }
  .prose h2:first-of-type { margin-top: 28px; }
  .prose a { color: var(--signal-2); }
  .prose a:hover { text-decoration: underline; }
  .prose em { color: var(--fg-3); }
  .prose hr { border: none; border-top: 1px solid var(--line); margin: 36px 0; }
  .prose blockquote { margin: 16px 0 0; padding: 12px 16px; border-left: 2px solid var(--line-3); background: var(--bg-sub); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; color: var(--fg-3); }
  .prose blockquote p { margin-top: 0; }
  .prose code { font-family: var(--font-mono); font-size: 0.9em; background: var(--surface-2); border: 1px solid var(--line-2); border-radius: 5px; padding: 1px 5px; color: var(--fg-2); }
  .prose ol { margin: 12px 0 0; padding-left: 20px; }
  .prose ol li { font-size: var(--fs-sm); color: var(--fg-3); line-height: 1.7; }
  .prose table { width: 100%; border-collapse: collapse; margin: 18px 0 0; font-size: var(--fs-sm); display: block; overflow-x: auto; }
  .prose thead { background: var(--bg-sub); }
  .prose th, .prose td { border: 1px solid var(--line-2); padding: 9px 12px; text-align: left; color: var(--fg-3); line-height: 1.55; vertical-align: top; }
  .prose th { color: var(--fg-2); font-weight: 600; white-space: nowrap; }
  .prose td strong, .prose th strong { color: var(--fg-2); }
</style>

<script>
  function show(k: string) {
    if (k !== 'terms' && k !== 'privacy') k = 'terms';
    document.querySelectorAll<HTMLElement>('.legal-doc').forEach((el) => {
      el.style.display = el.dataset.k === k ? '' : 'none';
    });
    document.querySelectorAll<HTMLButtonElement>('.legal-tab').forEach((b) => b.classList.toggle('on', b.dataset.k === k));
    if (history.replaceState) history.replaceState(null, '', '#' + k);
  }
  document.querySelectorAll<HTMLButtonElement>('.legal-tab').forEach((b) =>
    b.addEventListener('click', () => show(b.dataset.k!))
  );
  show((location.hash || '#terms').slice(1));
</script>
