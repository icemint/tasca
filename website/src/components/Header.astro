---
import BrandMark from './BrandMark.astro';
import { GITHUB_URL, APP_URL } from '../config';

// Section anchors only resolve on the home page; on sub-pages they deep-link home.
interface Props {
  /** when true, in-page anchors (#routing…) are used as-is; otherwise prefixed with "/" */
  home?: boolean;
}
const { home = false } = Astro.props;
const h = (anchor: string) => (home ? anchor : `/${anchor}`);
---
<header class="header">
  <div class="container nav">
    <div class="nav-left">
      <BrandMark />
      <nav aria-label="Primary">
        <ul class="nav-links">
          <li><a href={h('#routing')}>How it works</a></li>
          <li><a href={h('#github')}>Automation</a></li>
          <li><a href="/security">Security</a></li>
          <li><a href="/docs">Docs</a></li>
        </ul>
      </nav>
    </div>
    <div class="nav-right">
      <a class="nav-ghost hide-sm" href={GITHUB_URL} target="_blank" rel="noopener">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-.88-.01-1.73-2.78.62-3.37-1.37-3.37-1.37-.45-1.18-1.11-1.49-1.11-1.49-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.06 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.27 2.75 1.05A9.4 9.4 0 0112 6.84c.85 0 1.71.12 2.51.34 1.91-1.32 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.93-2.34 4.79-4.57 5.05.36.32.68.94.68 1.91 0 1.38-.01 2.49-.01 2.83 0 .27.18.6.69.49A10.02 10.02 0 0022 12.25C22 6.58 17.52 2 12 2z"/></svg>
        GitHub
      </a>
      <a class="btn btn-primary btn-sm" href={APP_URL}>Get started</a>
    </div>
  </div>
</header>
