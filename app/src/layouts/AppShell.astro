---
// The authenticated app chrome (app.tasca.dev). Topbar + left rail nav + themed
// surface, mirroring the design system's .surface-app scaffold (roster.css) and
// the website Base layout's head/theme handling. Static output; each page slots
// a client island into <main id="main">.
import '../styles/tasca.css';
import '../styles/tokens.css';
import '../styles/roster.css';
import '../styles/app-views.css';
import '../styles/monitoring.css';
import '../styles/connections.css';
import '../styles/settings.css';
import '../styles/invite.css';
import '../styles/pm-assistant.css';
import '../styles/states.css';
import '../styles/onboarding.css';
import '../styles/project-switcher.css';
import '../styles/a11y.css';
import { MARK, I } from '../lib/icons';

interface Props {
  title: string;
  active?: 'roster' | 'monitoring' | 'connections' | 'pm-assistant' | 'settings' | 'onboarding';
}
const { title, active } = Astro.props;

const nav = [
  { key: 'roster', href: '/roster', label: 'Roster', icon: I.roster },
  { key: 'monitoring', href: '/monitoring', label: 'Monitoring', icon: I.monitor },
  { key: 'connections', href: '/connections', label: 'Connections', icon: I.plug },
  { key: 'pm-assistant', href: '/pm-assistant', label: 'PM assistant', icon: I.spark },
  { key: 'settings', href: '/settings', label: 'Settings', icon: I.gear },
];
---
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} · Tasca</title>
  <meta name="description" content="Tasca — your AI dev team, named, capable, and working in the tools you already use." />
  <meta name="robots" content="noindex" />
  <script is:inline>
    (function () { try { document.documentElement.setAttribute('data-theme', localStorage.getItem('tasca-theme') || 'dark'); } catch (e) {} })();
  </script>
  <script is:inline>
    (function () { try { document.documentElement.setAttribute('data-rail', localStorage.getItem('tasca-rail') || 'expanded'); } catch (e) {} })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta name="theme-color" content="#090D14" />
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  <div class="surface-app">
    <header class="app-topbar">
      <a class="onb-brand" href="/roster" aria-label="Tasca">
        <span class="onb-mark" set:html={MARK} /><span class="brand-word"><span class="a">Tas</span><span class="b">ca</span></span>
      </a>
      <div class="topbar-right">
        <div class="psw" data-project-switcher aria-label="Project scope"></div>
        <span class="ro-badge" title="Read-only console — Tasca is in read-only mode today; agent and task actions arrive with the write API">Read-only</span>
        <span class="theme-seg" role="group" aria-label="Theme">
          <button data-t="dark" type="button" aria-label="Dark theme" aria-pressed="true">Dark</button>
          <button data-t="light" type="button" aria-label="Light theme" aria-pressed="false">Light</button>
        </span>
      </div>
    </header>
    <div class="app-body">
      <nav id="app-rail" class="app-rail" aria-label="Sections">
        {nav.map((n) => (
          <a class={`rail-item${active === n.key ? ' is-on' : ''}`} href={n.href} aria-label={n.label} aria-current={active === n.key ? 'page' : undefined} title={n.label}>
            <span class="rail-ico" set:html={n.icon} />
            <span class="rail-label">{n.label}</span>
          </a>
        ))}
        <span class="rail-spacer" aria-hidden="true"></span>
        <button type="button" class="rail-btn rail-toggle" data-rail-toggle aria-controls="app-rail" aria-expanded="true" aria-label="Collapse navigation">
          <span class="rail-ico" set:html={I.chevronsLeft} />
        </button>
      </nav>
      <div class="app-main">
        <main id="main" class="main-scroll">
          <slot />
        </main>
      </div>
    </div>
  </div>

  <script>
    // Finish a pending invite if the user signed in via the accept page (slice 3.5-B.3.2).
    // No-op when nothing is pending; runs at most once; never throws.
    import { consumePendingInvite } from '../lib/invite-consume';
    void consumePendingInvite();
  </script>

  <script>
    // Project switcher (slice Project-B): scope every task view to one project (or "All projects").
    // Reads the project list + active id once on shell load; selecting reloads to re-fetch the
    // server-filtered task set. Non-essential chrome — a read failure simply leaves it empty.
    import { mountProjectSwitcher } from '../lib/project-switcher';
    const host = document.querySelector<HTMLElement>('[data-project-switcher]');
    if (host) void mountProjectSwitcher(host);
  </script>

  <script>
    function syncTheme(t: string) {
      document.documentElement.setAttribute('data-theme', t);
      document.querySelectorAll<HTMLButtonElement>('.theme-seg button').forEach((b) => {
        const on = b.dataset.t === t;
        b.classList.toggle('on', on);
        b.setAttribute('aria-pressed', String(on));
      });
    }
    let t = 'dark';
    try { t = localStorage.getItem('tasca-theme') || 'dark'; } catch (e) {}
    syncTheme(t);
    document.querySelectorAll<HTMLButtonElement>('.theme-seg button').forEach((b) =>
      b.addEventListener('click', () => {
        const v = b.dataset.t!;
        try { localStorage.setItem('tasca-theme', v); } catch (e) {}
        syncTheme(v);
      })
    );
  </script>

  <script>
    // Rail collapse toggle (#353). State lives on documentElement[data-rail] (set pre-paint
    // by the head inline script), mirrored to localStorage. Mirrors the theme-persistence pattern.
    const railBtn = document.querySelector<HTMLButtonElement>('[data-rail-toggle]');
    function syncRail(state: 'expanded' | 'collapsed') {
      document.documentElement.setAttribute('data-rail', state);
      const expanded = state === 'expanded';
      railBtn?.setAttribute('aria-expanded', String(expanded));
      railBtn?.setAttribute('aria-label', expanded ? 'Collapse navigation' : 'Expand navigation');
    }
    let railState: 'expanded' | 'collapsed' = 'expanded';
    try { railState = localStorage.getItem('tasca-rail') === 'collapsed' ? 'collapsed' : 'expanded'; } catch (e) {}
    syncRail(railState);
    railBtn?.addEventListener('click', () => {
      railState = railState === 'expanded' ? 'collapsed' : 'expanded';
      try { localStorage.setItem('tasca-rail', railState); } catch (e) {}
      syncRail(railState);
    });
  </script>
</body>
</html>
