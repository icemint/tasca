---
import AppShell from '../layouts/AppShell.astro';
---
<AppShell title="Onboarding" active="onboarding">
  <div id="view"></div>
</AppShell>
<script>
  import { mount } from '../lib/mount';
  import { loadOnboarding, wireOnboarding } from '../lib/views/onboarding';
  const el = document.getElementById('view');
  if (el) void mount(el, loadOnboarding, wireOnboarding);
</script>
