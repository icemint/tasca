# Tasca — self-host configuration
#
# Copy to `.env` (git-ignored) and fill in. `docker compose` reads this file.
# Vars are grouped by when you need them:
#   TIER 1 — required to boot and log in
#   TIER 2 — GitHub App: needed to dispatch agents against a repo (the "step 2" after first login)
#   TIER 3 — optional features (Shortcut intake, email invites, git attribution)
# Everything the container wires itself (sockets, ports, dispatch mode, paths) is NOT here —
# the image and docker-compose.yml set those; you don't touch them.
#
# See SELF_HOST.md for the full walkthrough.

# ─────────────────────────────────────────────────────────────────────────────
# TIER 1 — required to boot and log in
# ─────────────────────────────────────────────────────────────────────────────

# Postgres password. docker-compose.yml builds DATABASE_URL from this and runs a
# bundled postgres:17-alpine. Set a real value; do not ship the default.
POSTGRES_PASSWORD=change-me

# To use an EXTERNAL/managed Postgres instead of the bundled one, uncomment and point
# this at it (and remove the `postgres` service from docker-compose.yml). When unset,
# compose injects postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/tasca.
# DATABASE_URL=postgresql://user:password@host:5432/tasca

# Anthropic API key. The worker holds it and injects it on the HTTPS leg to Anthropic;
# it never crosses to the agent-runner (which is keyless by design). Required for agents
# to run. Get one at https://console.anthropic.com/.
ANTHROPIC_API_KEY=sk-ant-...

# Single-tenant mode — set `on` for a self-hosted instance. On first boot the worker
# provisions one instance organization (`org_instance`) and enrolls every login into it.
TASCA_SINGLE_TENANT=on

# OAuth login (all FIVE are required together — if any is missing, login is disabled and
# the API fails closed with 503; there is no anonymous mode in a production container).
# Create a GitHub OAuth app (https://github.com/settings/developers) and a Google OAuth
# client (https://console.cloud.google.com/apis/credentials), each with the callback
# <OAUTH_REDIRECT_BASE>/api/auth/<github|google>/callback.
OAUTH_REDIRECT_BASE=http://localhost:3000
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# TIER 2 — recommended (unlock the full product); all optional for first boot
# ─────────────────────────────────────────────────────────────────────────────

# Vault master key for the BYOK vendor-credential store (AES-256-GCM). Needed to store
# per-agent vendor keys through the UI. Optional for first boot — agents run on the
# worker's ANTHROPIC_API_KEY above; when this is unset the BYOK surface fails closed (503)
# and nothing else is affected. Generate a 32-byte key:
#   openssl rand -hex 32
# (32-byte hex or base64; anything else is ignored and the surface stays disabled.)
TASCA_SECRET_STORE_KEY=

# GitHub App — dispatch agents against a repo + PR write-back. Optional for first boot;
# required before an agent can clone a repo and open a PR. Create a GitHub App, install it
# on your repos, then fill these in. See SELF_HOST.md.
#
# Numeric App ID.
GITHUB_APP_ID=
# The App's PEM private key. Multiline is fine; if your secret store is single-line,
# base64-encode the PEM and paste that (the worker decodes either form).
GITHUB_APP_PRIVATE_KEY=
# The App's URL slug (the trailing segment of github.com/apps/<slug>) — powers the
# in-product "Connect GitHub" install flow.
GITHUB_APP_SLUG=
# Webhook secret you set on the App; verifies inbound webhook signatures (HMAC-SHA-256).
GITHUB_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# TIER 3 — optional features
# ─────────────────────────────────────────────────────────────────────────────

# Shortcut intake (HMAC secret from the Shortcut Outgoing Webhook). When unset,
# /webhooks/shortcut returns 401. (Write-back is a separate, not-yet-shipped follow-on.)
SHORTCUT_WEBHOOK_SECRET=

# Email invites (org member invitations). Both are needed to send invite emails;
# when unset, invites are generated but not emailed.
RESEND_API_KEY=
TASCA_INVITE_FROM=

# Name an EXISTING organization as the instance org instead of auto-provisioning a fresh
# one. If set, that org MUST already exist (a typo'd value fails fast at boot, by design).
# TASCA_INSTANCE_ORG_ID=

# Git author identity for the commits agents make. Defaults to the machine identity.
# TASCA_GIT_AUTHOR_NAME=
# TASCA_GIT_AUTHOR_EMAIL=

# ─────────────────────────────────────────────────────────────────────────────
# TIER 4 — advanced tuning (all optional; sane in-code defaults — leave unset unless
# you know you need them)
# ─────────────────────────────────────────────────────────────────────────────

# Coordination-tier LLM routing: a lightweight classifier refines tier estimates. Off by
# default (pure heuristics); set `on` to enable. TASCA_LLM_MODEL overrides the model.
# TASCA_LLM=on
# TASCA_LLM_MODEL=

# PM-assistant proposals (advisory triage/decomposition). Off by default.
# TASCA_PM_ASSISTANT=on

# Escalation breaker: consecutive-failure count before a task re-tiers/escalates.
# TASCA_BREAKER_THRESHOLD=

# Max concurrent in-flight tasks per project.
# TASCA_PER_PROJECT_LIMIT=

# Agent execution timeout (ms) and the runner's job-claim poll interval (ms).
# TASCA_AGENT_TIMEOUT_MS=
# TASCA_RUNNER_WAIT_MS=

# Security exception: comma-separated extra env names to pass through to the agent process
# (the allowlist is deny-by-default; widen it only deliberately).
# TASCA_AGENT_ENV_PASSTHROUGH=
